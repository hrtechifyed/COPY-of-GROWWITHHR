      "id": "COW-DEF-001",
      "term": "Employer",
      "definition": "Employer as defined under the Code on Wages, 2019."
    },
    {
      "id": "COW-DEF-002",
      "term": "Employee",
      "definition": "Employee as defined under the Code on Wages, 2019, subject to the provision being applied."
    },
    {
      "id": "COW-DEF-003",
      "term": "Wages",
      "definition": "Remuneration determined under the statutory definition of wages, including the applicable inclusions, exclusions and adjustment mechanism."
    },
    {
      "id": "COW-DEF-004",
      "term": "Appropriate Government",
      "definition": "The Central Government or the relevant State Government determined under the Code for the establishment or employment concerned."
    }
  ],
