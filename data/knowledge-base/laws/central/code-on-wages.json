  "exceptions": [
    {
      "id": "COW-EX-001",
      "title": "Appropriate Government Rules and Notifications",
      "description": "Minimum wage rates, forms, authorities and procedural requirements depend on whether the Central Government or a State or Union Territory is the appropriate government."
    },
    {
      "id": "COW-EX-002",
      "title": "Saved Legacy Instruments",
      "description": "Notifications, orders, wage rates and other actions under the repealed wage enactments continue only to the extent preserved by section 69 and until replaced or repealed under the Code."
    }
  ],
  "recommendations": [
    {
      "id": "COW-REC-001",
      "title": "Maintain a Wage Component Mapping",
      "description": "Map every payroll component against the statutory wage definition and retain the calculation supporting any required adjustment."
    },
    {
      "id": "COW-REC-002",
      "title": "Track Wage Notifications by Location",
      "description": "Maintain a location and employment-category register of current minimum wage, variable dearness allowance and floor-wage notifications."
    },
    {
      "id": "COW-REC-003",
      "title": "Review Payroll Controls Monthly",
      "description": "Reconcile wage periods, payment dates, overtime, deductions, bonus eligibility, wage slips and statutory registers each month."
    }
