      "id": "OSH-DEF-001",
      "term": "Employer",
      "definition": "Employer responsible for providing a safe and healthy workplace."
    },
    {
      "id": "OSH-DEF-002",
      "term": "Employee",
      "definition": "Employee covered under the Occupational Safety, Health and Working Conditions Code."
    },
    {
      "id": "OSH-DEF-003",
      "term": "Workplace",
      "definition": "Premises where employees perform work covered by the Code."
    }
  ],
