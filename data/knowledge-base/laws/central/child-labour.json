  "definitions": [
    {
      "id": "CL-DEF-001",
      "term": "Child",
      "definition": "A person who has not completed fourteen years of age."
    },
    {
      "id": "CL-DEF-002",
      "term": "Adolescent",
      "definition": "A person who has completed fourteen years but has not completed eighteen years."
    },
    {
      "id": "CL-DEF-003",
      "term": "Employer",
      "definition": "Employer responsible for compliance under the Act."
    }
  ],
