# Gmail account used to send emails.
GMAIL_USER=youraccount@gmail.com

# Google App Password, not your ordinary Gmail password.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address that receives an internal lead notification.
INTERNAL_NOTIFICATION_EMAIL=youraccount@gmail.com

# Address that receives replies from customers.
REPLY_TO_EMAIL=youraccount@gmail.com

# Used only for local development.
# Hosting platforms usually provide their own PORT value.
PORT=3000
