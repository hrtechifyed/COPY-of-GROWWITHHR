# Gmail address that sends the messages.
GMAIL_USER=youraccount@gmail.com

# OAuth client created in Google Cloud.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth refresh token generated for the same Gmail account.
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Address that receives the internal lead notification.
INTERNAL_NOTIFICATION_EMAIL=youraccount@gmail.com

# Address that receives replies from customers.
REPLY_TO_EMAIL=youraccount@gmail.com

# Local development only. Render supplies PORT automatically.
PORT=3000
